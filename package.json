{
	"name": "@leitware/composables",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "bun run --filter '@leitware/composables-cli' build",
		"dev": "bun run --cwd packages/showcase dev",
		"test": "bun run --filter '@leitware/composables-cli' test",
		"prepare": "git config core.hooksPath .githooks"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	},
	"dependencies": {
		"@fontsource-variable/bricolage-grotesque": "^5.2.10",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource/ibm-plex-sans": "^5.2.8"
	}
}
