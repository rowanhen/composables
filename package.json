{
	"name": "@leitware/composables",
	"version": "0.1.0",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"rules",
		"src"
	],
	"exports": {
		".": "./src/index.ts",
		"./ai": "./src/opinionated/ai/index.ts",
		"./styles.css": "./dist/styles.css",
		"./presets/*": "./dist/presets/*"
	},
	"scripts": {
		"dev": "vite showcase",
		"lint": "oxlint",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"typecheck": "tsc --noEmit",
		"hooks:install": "git config core.hooksPath .githooks",
		"generate:palette": "bun scripts/generate-css.ts",
		"generate:presets": "bun scripts/generate-preset-css.ts",
		"generate:css": "bun run generate:palette && bun run generate:presets",
		"generate:showcase-routes": "bun scripts/generate-showcase-routes.ts",
		"generate:rules": "bun scripts/generate-rules.ts",
		"build:css": "bun scripts/build-css.ts",
		"prepack": "bun run build:css",
		"test:tokens": "bun scripts/check-token-system.ts",
		"test:rules": "bun scripts/generate-rules.ts --check",
		"test:css": "bun scripts/test-downstream-css.ts",
		"deploy:showcase": "./scripts/deploy-showcase.sh"
	},
