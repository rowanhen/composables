language js

`"$value"` where {
  $value <: r"(^|\s)(disabled:|group-has-disabled/)opacity-\d+(\/|\s|$)",
  register_diagnostic(
    span = $value,
    message = "Hardcoded disabled opacity detected. Use the DISABLED_OPACITY constant from @/lib/utils or opacity-disabled.",
    severity = "error"
  )
}
