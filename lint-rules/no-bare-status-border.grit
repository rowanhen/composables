language js

`"$value"` where {
  $value <: r"(^|\s)(border-(critical|success|warning|info)|ring-(critical|success|warning|info))(\/|\s|$)",
  register_diagnostic(
    span = $value,
    message = "Bare status border/ring detected. Use border-stroke-{status} or ring-stroke-{status} instead (e.g., border-stroke-critical, ring-stroke-critical/20).",
    severity = "error"
  )
}
