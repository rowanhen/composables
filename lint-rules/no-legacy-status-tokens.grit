language js

`"$value"` where {
  $value <: r"(^|\s)(border-border-(critical|success|warning|info)|ring-border-(critical|success|warning|info)|text-critical-text)(\/|\s|$)",
  register_diagnostic(
    span = $value,
    message = "Legacy status token name detected. Use the updated names: border-stroke-{status}, ring-stroke-{status}, text-critical.",
    severity = "error"
  )
}
