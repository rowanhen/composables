{
  "$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
  "overrides": [
    {
      "includes": ["src/**/*.ts", "src/**/*.tsx"],
      "excludes": [
        "src/components/ui/**/*",
        "src/components/ui-extended/**/*"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/components/ui/*"],
                    "message": "Import ui primitives only inside ui/ or ui-extended/ components. Use the ui-extended/ version or create a wrapper."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
