{
	"linter": {
		"rules": {
			"style": {
				"noRestrictedImports": {
					"level": "warn",
					"options": {
						"paths": {
							"lucide-react": "Do not import icons directly from 'lucide-react' in app code. Use '@/components/ui/icon' for consistent sizing via design tokens."
						}
					}
				}
			}
		}
	},
	"overrides": [
		{
			"includes": [
				"src/components/ui/**",
				"src/components/ui-opinionated/**"
			],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": "off"
					}
				}
			}
		}
	]
}
