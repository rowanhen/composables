{
	"linter": {
		"rules": {
			"style": {
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": ["@/components/_internal/*"],
								"message": "Do not import directly from 'components/_internal/'. Import from 'components/ui-opinionated/' instead."
							}
						]
					}
				}
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/components/ui-opinionated/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": "off"
					}
				}
			}
		}
	]
}
