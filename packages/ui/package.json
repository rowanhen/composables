{
  "name": "@leitware/composables-cli",
  "version": "0.21.0",
  "description": "Opinionated React component library — extended shadcn/ui-style components with design tokens",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./src/styles/composable.css",
    "./tokens.css": "./src/styles/tokens.css",
    "./presets/*": "./src/styles/presets/*",
    "./tailwind-preset": "./src/tailwind/composables-preset.ts",
    "./rules/*": "./src/rules/*",
    "./scripts/*": "./src/scripts/*"
  },
  "files": [
    "dist",
    "src/styles",
    "src/styles/tokens",
    "src/styles/presets",
    "src/tailwind",
    "src/rules",
    "src/scripts"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.8.0",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.14.0",
    "react-dropzone": "^15.0.0",
    "react-resizable-panels": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "homepage": "https://rowanhen.github.io/composables/",
  "repository": {
    "type": "git",
    "url": "https://github.com/rowanhen/composables"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
