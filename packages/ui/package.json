{
  "name": "@leitware/composables-cli",
  "version": "0.21.0",
  "description": "Opinionated React component library — extended shadcn/ui-style components with design tokens",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./src/styles/composable.css",
    "./tailwind-preset": "./src/tailwind/composables-preset.ts",
    "./rules/*": "./src/rules/*",
    "./scripts/*": "./src/scripts/*"
  },
  "files": [
    "dist",
    "src/styles",
    "src/tailwind",
    "src/rules",
    "src/scripts"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.577.0",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.14.0",
    "react-dropzone": "^15.0.0",
    "react-resizable-panels": "^4.7.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "homepage": "https://rowanhen.github.io/composables/",
  "repository": {
    "type": "git",
    "url": "https://github.com/rowanhen/composables"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
