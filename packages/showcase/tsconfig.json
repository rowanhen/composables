{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2024", "DOM", "DOM.Iterable"],
		"baseUrl": ".",
		"jsx": "react-jsx",
		"noEmit": true,
		"paths": {
			"@/components/_internal/*": ["../ui/src/_internal/*"],
			"@/components/ui-opinionated/*": ["../ui/src/opinionated/*"],
			"@/lib/*": ["../ui/src/lib/*"],
			"@/hooks/*": ["../ui/src/hooks/*"],
			"@/*": ["./src/*"]
		}
	},
	"include": ["src"]
}
