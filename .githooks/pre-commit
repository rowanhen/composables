#!/bin/sh
# Build the library — catch compile errors before they hit CI
echo "🔨 Building library..."
bun run build || { echo "❌ Build failed. Fix errors before committing."; exit 1; }

# Run biome lint on staged files (errors block commit)
echo "🔍 Running biome lint..."
bunx biome lint --staged --no-errors-on-unmatched --diagnostic-level=error || { echo "❌ Lint errors found. Fix before committing."; exit 1; }

# Run no-arbitrary-tailwind lint (advisory — doesn't block)
bun packages/ui/src/scripts/lint-no-arbitrary.ts packages/ui/src packages/showcase/src || true
