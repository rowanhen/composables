echo "🔍 Running oxlint..."
bunx oxlint || { echo "❌ Lint errors found. Fix before committing."; exit 1; }

echo "🔎 Running prettier check..."
bunx prettier --check . || { echo "❌ Formatting errors found. Run 'bun run format' before committing."; exit 1; }

echo "🔎 Running typecheck..."
bun run typecheck || { echo "❌ Typecheck failed. Fix errors before committing."; exit 1; }
